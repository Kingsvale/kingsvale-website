HOST_PORT=8095
STUDIO_USER=kingsvale
STUDIO_PASSWORD=replace-with-a-rotated-editor-password
STUDIO_AUTH_TOKEN_SECRET=replace-with-a-long-random-auth-token-secret
CMS_ENCRYPTION_KEY=replace-with-a-long-random-cms-encryption-key

# Optional production hardening
STUDIO_TOTP_SECRET=
CMS_MAX_REVISIONS=5
CMS_MAX_BACKUPS=30
BACKUP_IMPORT_MAX_MB=25

# Local-to-production workflow:
# 1. Export JSON from local Studio > Backup.
# 2. Upload/redeploy the image in Portainer.
# 3. Import that JSON in production Studio > Backup.
# Keep the Docker volume and CMS_ENCRYPTION_KEY stable between redeploys.

# Optional Royal Mail or third-party tracking lookup
ROYAL_MAIL_TRACKING_API_URL=
ROYAL_MAIL_TRACKING_API_KEY=

# Optional Google Sheets sync for Studio > Settings > Google Sheet.
# Share the spreadsheet with the service-account email before enabling sync.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Alternative: paste the full service-account JSON into one environment variable.
GOOGLE_SERVICE_ACCOUNT_JSON=
PUBLIC_SITE_URL=https://www.kingsvalehomes.co.uk
GOOGLE_SHEETS_SYNC_TIMEOUT_MS=8000

# Optional lead forwarding
CONTACT_WEBHOOK_URL=
NEWSLETTER_WEBHOOK_URL=
LEAD_WEBHOOK_HMAC_SECRET=

# Optional IndexNow search-engine update pings
# Create a public file at https://www.kingsvalehomes.co.uk/<INDEXNOW_KEY>.txt
# whose content is exactly the key, then run: npm run submit:indexnow
INDEXNOW_HOST=www.kingsvalehomes.co.uk
INDEXNOW_KEY=
INDEXNOW_KEY_LOCATION=
